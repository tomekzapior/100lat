# Kontrakt środowiska dla przyszłego adaptera Supabase.
# Wydanie MVP działa wyłącznie w trybie demo i nie odczytuje tych wartości.
VITE_DATA_MODE=demo

# Publiczna konfiguracja przeglądarki. Klucz publishable/anon nie jest sekretem.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Konfiguracja wyłącznie serwerowa dla lokalnej pracy z Edge Functions.
# Nigdy nie dodawaj prefiksu VITE_ do wartości poniżej i nie commituj realnych kluczy.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
REMINDER_FROM_EMAIL=
REMINDER_CRON_SECRET=
